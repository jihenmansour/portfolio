\n    <div className='bg-white relative'>\n      <Header />\n      <Hero />\n      <About />\n      <Skills />\n      <Portfolio />\n      <Contact />\n      <Footer />\n      <BackTopBtn />\n    </div>\n  );\n};\n\nexport default App;\n","C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Hero.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Header.js",["114"],[],"import React, { useEffect, useState } from 'react';\n\n// import components\nimport Logo from '../assets/img/logo.svg';\nimport Nav from '../components/Nav';\nimport NavMobile from '../components/NavMobile';\nimport Socials from './Socials';\n\nconst Header = () => {\n  const [bg, setBg] = useState(false);\n\n  useEffect(() => {\n    window.addEventListener('scroll', () => {\n      return window.scrollY > 50 ? setBg(true) : setBg(false);\n    });\n  });\n\n  return (\n    <header\n      className={`${\n        bg ? 'bg-tertiary h-20' : 'h-24'\n      } flex items-center fixed top-0 w-full text-white z-10 transition-all duration-300`}\n    >\n      <div className='container mx-auto h-full flex items-center justify-between'>\n        {/* logo */}\n        <h1 className='font-sans text-2xl'>Jihen Mansour</h1>\n        {/* nav */}\n        <div className='hidden lg:block'>\n          <Nav />\n        </div>\n        {/* Socials */}\n        <div className='hidden lg:block'>\n          <Socials />\n        </div>\n        {/* nav mobile*/}\n        <div className='lg:hidden'>\n          <NavMobile />\n        </div>\n      </div>\n    </header>\n  );\n};\n\nexport default Header;\n","C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Brands.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\About.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Contact.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Portfolio.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Testimonials.js",["115","116"],[],"import React, { useEffect, useState } from 'react';\n\n// import components\nimport TestiSlider from './TestiSlider';\n\nconst Testimonials = () => {\n\n  return (\n    <section id='testimonials' className='section bg-secondary'>\n      <div className='container mx-auto'>\n        <div className='flex flex-col items-center text-center'>\n          <h2 className='section-title before:content-testimonials relative before:absolute before:opacity-40 before:-top-[2rem] before:-left-64 before:hidden before:lg:block'>\n            What other people say\n          </h2>\n          <p className='subtitle'>\n            Lorem ipsum dolor sit amet consectetur adipisicing elit. Fuga veniam\n            labore nisium illum cupiditate reiciendis a numquam\n          </p>\n        </div>\n        <TestiSlider />\n      </div>\n    </section>\n  );\n};\n\nexport default Testimonials;\n","C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Skills.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Footer.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\BackTopBtn.js",["117","118"],[],"import React, { useState, useEffect } from 'react';\n\n// import link\nimport { Link, animateScroll as scroll } from 'react-scroll';\n// import icon\nimport { ChevronUpIcon } from '@heroicons/react/outline';\n\nconst BackTopBtn = () => {\n  const [show, setShow] = useState(false);\n  useEffect(() => {\n    window.addEventListener('scroll', () => {\n      return window.scrollY > 600 ? setShow(true) : setShow(false);\n    });\n  });\n  const scrollToTop = () => {\n    scroll.scrollToTop();\n  };\n  {\n    return (\n      show && (\n        <button\n          onClick={() => scrollToTop()}\n          className='bg-accent hover:bg-accent-hover text-white w-12 h-12 rounded-full fixed right-24 bottom-24 cursor-pointer flex justify-center items-center transition-all'\n        >\n          <ChevronUpIcon className='w-6 h-6' />\n        </button>\n      )\n    );\n  }\n};\n\nexport default BackTopBtn;\n","C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\data.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Socials.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Nav.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\NavMobile.js",[],[],"C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\TestiSlider.js",["119","120"],[],"import React from 'react';\n\n// testimonials data\nimport { testimonials } from '../data';\n\n// Import Swiper React components\nimport { Swiper, SwiperSlide } from 'swiper/react';\n\n// Import Swiper styles\nimport 'swiper/css';\nimport 'swiper/css/pagination';\nimport '../swiper.css';\n\n// import required modules\nimport { Autoplay, Pagination } from 'swiper';\n\n\nconst TestiSlider = () => {\n\n  return (\n    <>\n      <Swiper\n        pagination={{\n          clickable: true,\n        }}\n        autoplay={{\n          delay: 2500,\n          disableOnInteraction: false,\n        }}\n        \n        className='mySwiper'\n      >\n        {testimonials.map((item, index) => {\n          const { authorImg, authorText, authorName, authorPosition } = item;\n          return (\n            <SwiperSlide key={index}>\n              <div\n                className='flex flex-col lg:flex-row gap-12 lg:gap-32'\n              >\n                <div\n                  className='w-48 h-48 lg:w-[328px] lg:h-[328px]'\n                >\n                  <img className='rounded-2xl' src={authorImg} alt='' />\n                </div>\n                <div\n                  className='flex flex-col max-w-3xl'\n                >\n                  <h5 className='font-body text-2xl mb-8 italic font-normal'>\n                    {authorText}\n                  </h5>\n                  <div>\n                    <p className='text-lg text-accent'>{authorName}</p>\n                    <p>{authorPosition}</p>\n                  </div>\n                </div>\n              </div>\n            </SwiperSlide>\n          );\n        })}\n      </Swiper>\n    </>\n  );\n};\n\nexport default TestiSlider;\n","C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Projects.js",["121","122","123","124"],[],"import React, { useState, useEffect } from 'react';\nimport {AiOutlineArrowRight} from'react-icons/ai';\n\n// import data\nimport { projectsData } from '../data';\nimport { projectsNav } from '../data';\n\n// import components\nimport Project from './Project';\n\nconst Projects = () => {\n  const [item, setItem] = useState({ name: 'all' });\n  const [projects, setProjects] = useState([]);\n  const [active, setActive] = useState(0);\n\n  useEffect(() => {\n    // get projects based on item\n    if (item.name === 'all') {\n      setProjects(projectsData);\n    } else {\n      const newProjects = projectsData.filter((project) => {\n        return project.category.toLowerCase() === item.name;\n      });\n      setProjects(newProjects);\n    }\n  }, [item]);\n\n  const handleClick = (e, index) => {\n    setItem({ name: e.target.textContent.toLowerCase() });\n    setActive(index);\n  };\n\n  return (\n    <div>\n      {/* projects */}\n      <section className='grid gap-y-12 lg:grid-cols-2 lg:gap-x-8 lg:gap-y-8'>\n        {projects.map((item) => {\n          return <Project item={item} key={item.id} />;\n        })}\n      </section>\n    </div>\n  );\n};\n\nexport default Projects;\n","C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Skillbar.js",["125","126","127","128"],[],"import React from 'react';\n\nimport VisibilitySensor from \"react-visibility-sensor\";\nimport {CircleProgress} from 'react-gradient-progress'\nimport { CircularProgressbar, buildStyles } from \"react-circular-progressbar\";\nimport \"react-circular-progressbar/dist/styles.css\";\nimport { skills } from '../data';\n\nconst Skillbar = () => {\n  return ( \n    <div id=\"main\" class=\"grid gap-10 lg:grid-cols-2   \">\n  {skills.map((item, index) => {\n    return(\n      <div className='p-5'>\n      <p className='text-white'>{item.name}</p>\n  <div class=\" bg-black shadow-sm overflow-hidden \">\n    <div class=\"relative h-2 flex items-center justify-center\">\n      <div class=\"transition-all ease-out duration-1000 absolute top-0 bottom-0 left-0 bg-accent\" style={{width:item.per}}></div>\n    </div>\n  </div>\n  </div>\n    )\n  })}\n  </div>\n  )\n}\n\nexport default Skillbar","C:\\Users\\lenOvo10Pro\\Downloads\\portfolio-main\\portfolio-main\\src\\components\\Project.js",["129","130","131","132","133","134"],[],"import {React, useState} from 'react';\nimport {AiOutlineArrowRight} from'react-icons/ai';\n\n\nconst Project = ({ item }) => {\n  const [isHovering, setIsHovering] = useState(false);\n\n  const handleMouseOver = () => {\n    setIsHovering(true);\n  };\n\n  const handleMouseOut = () => {\n    setIsHovering(false);\n  };\n\n\n  return (\n    <div key={item.id} className='flex flex-col items-center text-center'>\n      <div className='mb-8'>\n      <figure class=\"relative inline-block overflow-hidden text-base text-left \n      before:absolute before:inset-2.5  before:top-full before:bg-image snip1584\">\n        <img className='h-100 max-w-lg rounded-lg align-top' src={item.image}/>\n    <figcaption className='absolute inset-0 items-center flex flex-col justify-center'>\n    <h3 className='m-0 opacity-0 tracking-wider capitalize text-sm mb-3'>{item.category}</h3>\n    <div className=\"gap-4 grid grid-flow-col auto-cols-max\">\n    <h5 className='m-0 opacity-0 tracking-wider'><a href={item.github} target=\"_blank\">Github</a></h5>\n    </div>\n    \n  </figcaption>\n   </figure>   \n      </div>\n      <h3 className='text-2xl font-semibold capitalize mb-3'>{item.name}</h3>\n      <p className='text-base max-w-md'>\n        {item.description}\n      </p>\n    </div>\n  );\n};\n\nexport default Project;\n",{"ruleId":"135","severity":1,"message":"136","line":6,"column":8,"nodeType":"137","messageId":"138","endLine":6,"endColumn":14},{"ruleId":"135","severity":1,"message":"139","line":10,"column":8,"nodeType":"137","messageId":"138","endLine":10,"endColumn":22},{"ruleId":"135","severity":1,"message":"140","line":13,"column":8,"nodeType":"137","messageId":"138","endLine":13,"endColumn":20},{"ruleId":"135","severity":1,"message":"141","line":4,"column":8,"nodeType":"137","messageId":"138","endLine":4,"endColumn":12},{"ruleId":"135","severity":1,"message":"142","line":1,"column":17,"nodeType":"137","messageId":"138","endLine":1,"endColumn":26},{"ruleId":"135","severity":1,"message":"143","line":1,"column":28,"nodeType":"137","messageId":"138","endLine":1,"endColumn":36},{"ruleId":"135","severity":1,"message":"144","line":4,"column":10,"nodeType":"137","messageId":"138","endLine":4,"endColumn":14},{"ruleId":"145","severity":1,"message":"146","line":18,"column":3,"nodeType":"147","messageId":"148","endLine":29,"endColumn":4},{"ruleId":"135","severity":1,"message":"149","line":15,"column":10,"nodeType":"137","messageId":"138","endLine":15,"endColumn":18},{"ruleId":"135","severity":1,"message":"150","line":15,"column":20,"nodeType":"137","messageId":"138","endLine":15,"endColumn":30},{"ruleId":"135","severity":1,"message":"151","line":2,"column":9,"nodeType":"137","messageId":"138","endLine":2,"endColumn":28},{"ruleId":"135","severity":1,"message":"152","line":6,"column":10,"nodeType":"137","messageId":"138","endLine":6,"endColumn":21},{"ruleId":"135","severity":1,"message":"153","line":14,"column":10,"nodeType":"137","messageId":"138","endLine":14,